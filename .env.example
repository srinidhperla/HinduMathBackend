PORT=5000
DATABASE_URL=url
JWT_SECRET=replace_with_a_strong_secret
JWT_EXPIRES_IN=365d
GOOGLE_CLIENT_ID=

# Comma-separated frontend origins
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# Optional unless online Razorpay payment is enabled
RAZORPAY_KEY=
RAZORPAY_KEY_SECRET=

# Optional email alerts
# Recommended for production on Render (HTTPS API email provider)
RESEND_API_KEY=
EMAIL_FROM=
# SMTP fallback (usually for local development)
SMTP_HOST=
SMTP_PORT=587
# If blank, backend auto-uses true for port 465 and false otherwise.
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
ADMIN_ALERT_EMAIL=
ADMIN_CONTACT_EMAIL=

# Appwrite image storage
APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
APPWRITE_PROJECT_ID=
APPWRITE_API_KEY=
APPWRITE_BUCKET_ID=

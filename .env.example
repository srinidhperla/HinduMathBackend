PORT=5000
DATABASE_URL=
JWT_SECRET=
JWT_EXPIRES_IN=7d
GOOGLE_CLIENT_ID=

# Comma-separated frontend origins
CORS_ORIGIN=http://localhost:5173,http://localhost:3000
FRONTEND_URL=http://localhost:5173

# Optional unless online Razorpay payment is enabled
RAZORPAY_KEY=
RAZORPAY_KEY_SECRET=

# Optional email alerts
# Recommended for production on Render (HTTPS API email provider)
RESEND_API_KEY=
EMAIL_FROM=
ADMIN_ALERT_EMAILS=
ADMIN_ALERT_EMAIL=
ADMIN_CONTACT_EMAILS=
ADMIN_CONTACT_EMAIL=

# Optional Redis cache URL (falls back to in-memory cache when unavailable)
# Use rediss:// for Upstash TLS connections
REDIS_URL=
# Optional explicit Upstash REST credentials (preferred on Render/serverless)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Cloudinary image storage
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# Optional folder (defaults to "bakery")
CLOUDINARY_FOLDER=bakery

# Private key used by /api/alert/orders (REQUIRED - generate a strong random key)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ALERT_ORDERS_PRIVATE_KEY=

# VAPID keys for web push notifications
# Generate with: npx web-push generate-vapid-keys
VAPID_SUBJECT=
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# Firebase for mobile push notifications
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Google Maps API (optional)
GOOGLE_MAPS_API_KEY=
